# .env.example
# WhatsApp Bokun Bot — backend environment variables.
# Copy to .env.local for local development (gitignored).
# In production: set these as environment variables in the Render Web Service.
#
# Legend:
#   REQUIRED    — app will not start or will fail silently without this
#   DEPLOY-ONLY — used only during deployment pipeline, not read by the running app
#   SITUATIONAL — required only when using a specific auth method or feature
#   OPTIONAL    — has a safe default; set to override

# ─── Convex ────────────────────────────────────────────────────────────────
# From: Convex Dashboard > Deployment > Settings > Deployment URL
# Example: https://happy-animal-123.convex.cloud
# REQUIRED
CONVEX_URL=https://xxx.convex.cloud

# From: Convex Dashboard > Deployment > Settings > Deployment URL (Site URL)
# Example: https://happy-animal-123.convex.site
# SITUATIONAL — needed if HTTP Actions or Convex site URL references are used
CONVEX_SITE_URL=https://xxx.convex.site

# From: Convex Dashboard > Project Settings > Deploy Keys (Production type)
# Format: prod:qualified-jaguar-123|eyJ2...0=
# DEPLOY-ONLY — used by `npm run convex:deploy` in Render preDeployCommand.
#               NOT read by the running application. Must be set in Render before
#               first deploy or the preDeployCommand will hang waiting for browser auth.
CONVEX_DEPLOY_KEY=prod:...

# ─── Bokun API ─────────────────────────────────────────────────────────────
# Bokun REST API base URL.
# Production: https://api.bokun.io
# Sandbox/Test: https://api.bokuntest.com
# REQUIRED
BOKUN_BASE_URL=https://api.bokuntest.com

# From: Bokun vendor dashboard > API credentials
# SITUATIONAL — required when using HMAC-SHA1 auth (fallback when OAuth token unavailable)
BOKUN_ACCESS_KEY=
BOKUN_SECRET_KEY=

# ─── Bokun OAuth (Marketplace App) ─────────────────────────────────────────
# From: Bokun App Marketplace > Your App > Credentials
# REQUIRED for vendor onboarding flow (/oauth/authorize and /oauth/callback)
BOKUN_APP_CLIENT_ID=
BOKUN_APP_CLIENT_SECRET=

# Full URL to your /oauth/callback endpoint (must match the redirect URI configured in Bokun app)
# Local: https://your-tunnel.ngrok.io/oauth/callback
# Production: https://bokun-bot-api.onrender.com/oauth/callback
BOKUN_OAUTH_REDIRECT_URI=https://your-tunnel.ngrok.io/oauth/callback

# OAuth scopes requested from Bokun (space-separated)
# OPTIONAL — defaults to "bookings activities" if not set
BOKUN_OAUTH_SCOPES=bookings activities

# ─── Bokun Defaults (optional overrides) ───────────────────────────────────
# Default language for Bokun API responses (ISO 639-1 code)
# OPTIONAL — defaults to "EN"
# BOKUN_DEFAULT_LANG=EN

# Default currency for pricing (ISO 4217 code)
# OPTIONAL — defaults to "EUR"
# BOKUN_DEFAULT_CURRENCY=EUR

# Default Bokun domain used in OAuth flow
# OPTIONAL — set only if your Bokun account uses a custom domain
# BOKUN_DEFAULT_DOMAIN=

# ─── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────
# From: Meta Developer Console > App > WhatsApp > App Settings > App Secret
# Used to validate HMAC-SHA256 signature on incoming webhook POST requests.
# REQUIRED — webhooks fail HMAC check and are rejected if not set.
# Note: alias META_APP_SECRET is also accepted by the app (legacy name).
WHATSAPP_APP_SECRET=

# Token you choose when configuring the webhook in Meta Developer Console.
# Must match exactly the value entered in Meta > Webhooks > Verify Token.
# REQUIRED
WHATSAPP_VERIFY_TOKEN=

# Optional default token used by admin bootstrap endpoints when accessToken is
# not sent in request body.
# OPTIONAL
WHATSAPP_ACCESS_TOKEN=

# Optional alias for access token (legacy name accepted by the backend).
# OPTIONAL
META_ACCESS_TOKEN=

# Optional default WABA id used by admin channel bootstrap if request omits it.
# OPTIONAL
WHATSAPP_WABA_ID=

# Optional default phone number id used by /admin/bootstrap if request omits it.
# OPTIONAL
DEFAULT_WHATSAPP_PHONE_NUMBER_ID=

# ─── Admin API (bootstrap/operations) ──────────────────────────────────────
# Shared secret required by:
# - POST /admin/bootstrap
# - POST /admin/whatsapp/channel
# REQUIRED if using admin endpoints.
ADMIN_API_KEY=

# ─── OpenAI (LLM Agent — global fallback) ──────────────────────────────────
# Each tenant configures their own OpenAI key in the dashboard Settings > AI.
# This is the system-level fallback used when a tenant has no key configured.
# OPTIONAL — if not set and tenant has no key, bot responds asking to configure one
OPENAI_API_KEY=

# Default model for tenants that have not set a preferred model.
# OPTIONAL — defaults to "gpt-4o-mini"
OPENAI_MODEL=gpt-4o-mini

# ─── Observability (Sentry) ────────────────────────────────────────────────
# From: Sentry Dashboard > Project > Settings > Client Keys > DSN
# Sentry is a no-op if not set — safe to omit in local development.
# OPTIONAL
SENTRY_DSN=

# Sentry environment tag (appears in Sentry issue list for filtering).
# Values: development | staging | production
# OPTIONAL — defaults to "development"
SENTRY_ENVIRONMENT=development

# ─── Logging ───────────────────────────────────────────────────────────────
# Pino log level.
# Values: debug | info | warn | error
# OPTIONAL — defaults to "info". Use "debug" locally for verbose output.
LOG_LEVEL=info

# ─── Server ────────────────────────────────────────────────────────────────
# HTTP port the server listens on.
# Render sets PORT automatically for web services — do not override in production.
# OPTIONAL — set locally if port 3000 conflicts with another service.
PORT=3000

# Node.js environment. Controls framework-level optimizations.
# OPTIONAL — defaults to "development". Set to "production" in Render (done via render.yaml).
NODE_ENV=development

# ─── Rate Limiting (optional) ──────────────────────────────────────────────
# Max inbound WhatsApp messages per phone number per time window.
# OPTIONAL — defaults to 10 requests per 60000 ms (1 minute).
# RATE_LIMIT_MAX=10
# RATE_LIMIT_WINDOW_MS=60000

# ─── Debug (optional) ──────────────────────────────────────────────────────
# Enable verbose webhook debug logs. Do not enable in production (high log volume).
# Set to "1" to enable, leave unset or empty to disable.
# OPTIONAL
# WHATSAPP_WEBHOOK_DEBUG=1

# ─── Stripe Billing ────────────────────────────────────────────────────────
# From: Stripe Dashboard > Developers > API keys > Secret key (or Restricted key)
# REQUIRED for Stripe webhook processing (POST /stripe/webhook)
# Use "Restricted key" in production with only: Customers (read), Subscriptions (read)
STRIPE_SECRET_KEY=sk_live_...

# From: Stripe Dashboard > Developers > Webhooks > [your endpoint] > Signing secret
# CRITICAL: This secret differs between test mode (CLI) and production (Dashboard endpoint)!
#   - CLI test mode secret: whsec_... from `stripe listen --forward-to ...` (local only)
#   - Production secret: whsec_... from Dashboard > Webhooks > [endpoint] > Signing secret
# Steps to activate:
#   1. Stripe Dashboard > Developers > Webhooks > + Add endpoint
#   2. Endpoint URL: https://bokun-bot-api.onrender.com/stripe/webhook
#   3. Events to listen: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
#   4. Copy the "Signing secret" (whsec_...) shown after creating the endpoint
# REQUIRED for signature verification (POST /stripe/webhook returns 403 without this)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Stripe Price IDs (Checkout) ───────────────────────────────────────────
# Create products in Stripe Dashboard first, then copy the Price IDs here.
# From: Stripe Dashboard -> Products -> Create product -> Add price -> Copy price ID (price_...)
# REQUIRED for Stripe Checkout subscription flow (/api/create-checkout-session)
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...

# Frontend URL for Checkout success/cancel redirect
# Local: http://localhost:5173
# Production: https://your-dashboard.onrender.com (or custom domain)
FRONTEND_URL=http://localhost:5173

# ─── Server-to-Server Rate Limiting (optional) ─────────────────────────────
# Max requests per time window for Bokun and Stripe webhook endpoints.
# These are server-to-server endpoints — much higher limits than end-user WhatsApp.
# OPTIONAL — defaults to 300 requests per 60000 ms (1 minute).
# SERVER_WEBHOOK_RATE_MAX=300
# SERVER_WEBHOOK_RATE_WINDOW_MS=60000
