# frontend/.env.example
# Dashboard environment variables for the React Vite app.
# Copy to frontend/.env.local for local development (gitignored).
# In production: set these as environment variables in the Render Static Site service.
#
# VITE_ prefix is required — Vite only exposes variables with this prefix to
# client-side code. Variables without VITE_ are stripped at build time and will
# be undefined in the browser bundle.

# ─── Convex ────────────────────────────────────────────────────────────────
# From: Convex Dashboard > Deployment > Settings > Deployment URL
# Example: https://happy-animal-123.convex.cloud
# REQUIRED — the Convex client SDK fails silently if this is not set.
VITE_CONVEX_URL=https://xxx.convex.cloud

# ─── Backend API ───────────────────────────────────────────────────────────
# Backend API base URL — used for Stripe Checkout session creation from the frontend.
# Local: http://localhost:3000
# Production: https://bokun-bot-api.onrender.com (or your custom backend URL)
# REQUIRED for Assinatura tab (Stripe Checkout flow)
VITE_API_BASE_URL=http://localhost:3000
